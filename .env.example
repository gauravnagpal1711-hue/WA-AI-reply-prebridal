# ─────────────────────────────────────────────────────────────
#  Beauty Box AI Agent — Environment Variables
#  Copy this file to .env and fill in your values
#  NEVER share this file or commit it to GitHub
# ─────────────────────────────────────────────────────────────

# 1. Get this from console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# 2. Get these from panel.wapi.in.net → Your Instance
WAPI_INSTANCE_ID=your_instance_id_here
WAPI_TOKEN=your_token_here

# 3. Port (Railway sets this automatically, don't change)
PORT=3000
